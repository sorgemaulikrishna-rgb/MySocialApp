// ANALYTICS DASHBOARD (INSTAGRAM-LIKE)

// AGGREGATED USER ANALYTICS
app.get("/dashboard/user/:userId", async (req, res) => {
  const userId = req.params.userId;

  const posts = await Post.find({ userId });
  const reels = await Reel.find({ userId });
  const highlights = await Highlight.find({ userId });
  const likes = posts.reduce((acc, p) => acc + p.likes.length, 0);
  const comments = posts.reduce((acc, p) => acc + p.comments.length, 0);
  const shares = posts.reduce((acc, p) => acc + (p.shares ? p.shares.length : 0), 0);

  // Earnings
  const earnings = await Earning.find({ userId });
  const totalEarnings = earnings.reduce((acc, e) => acc + e.amount, 0);

  res.json({
    postsCount: posts.length,
    reelsCount: reels.length,
    highlightsCount: highlights.length,
    totalLikes: likes,
    totalComments: comments,
    totalShares: shares,
    totalEarnings
  });
});

// PLATFORM-WIDE DASHBOARD
app.get("/dashboard/platform", async (req, res) => {
  const totalUsers = await User.countDocuments();
  const totalPosts = await Post.countDocuments();
  const totalReels = await Reel.countDocuments();
  const totalComments = (await Post.find()).reduce((acc, p) => acc + p.comments.length, 0);
  const totalEarnings = (await Earning.find()).reduce((acc, e) => acc + e.amount, 0);

  res.json({
    totalUsers,
    totalPosts,
    totalReels,
    totalComments,
    totalEarnings
  });
});

// TRENDING CONTENT DASHBOARD
app.get("/dashboard/trending", async (req, res) => {
  const posts = await Analytics.find().sort({ likes: -1, views: -1 }).limit(10);
  const reels = await Reel.find().sort({ "likes.length": -1, "comments.length": -1 }).limit(10);

  res.json({ trendingPosts: posts, trendingReels: reels });
});
