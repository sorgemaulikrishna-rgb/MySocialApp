// OPTIMIZATION FOR INSTAGRAM-LIKE APP

const compression = require("compression");
const morgan = require("morgan");
const helmet = require("helmet");
const rateLimit = require("express-rate-limit");

// USE HELMET FOR SECURITY HEADERS
app.use(helmet());

// USE COMPRESSION FOR RESPONSE OPTIMIZATION
app.use(compression());

// LOGGING
app.use(morgan("tiny"));

// RATE LIMITING
const limiter = rateLimit({
  windowMs: 15 * 60 * 1000, // 15 minutes
  max: 100, // limit each IP to 100 requests per windowMs
  message: "Too many requests, please try again later."
});
app.use(limiter);

// CACHE STATIC FILES
const cacheTime = 24 * 60 * 60 * 1000; // 24 hours
app.use("/uploads", express.static(path.join(__dirname, "uploads"), { maxAge: cacheTime }));

// PAGINATION & QUERY OPTIMIZATION
app.get("/feed", async (req, res) => {
  const page = parseInt(req.query.page) || 1;
  const limit = parseInt(req.query.limit) || 10;
  const skip = (page - 1) * limit;

  const posts = await Post.find()
    .sort({ createdAt: -1 })
    .skip(skip)
    .limit(limit)
    .lean(); // lean() improves query speed by returning plain JS objects

  res.json(posts);
});

// INDEXING FOR FASTER QUERIES
Post.collection.createIndex({ userId: 1 });
Post.collection.createIndex({ createdAt: -1 });
User.collection.createIndex({ email: 1 });

// ASYNC PARALLEL OPERATIONS
const getAnalytics = async (postId) => {
  const [analytics, post] = await Promise.all([
    Analytics.findOne({ postId }),
    Post.findById(postId)
  ]);

  return { post, analytics };
};

// BULK UPDATE OPTIMIZATION
app.post("/analytics/updateBulk", async (req, res) => {
  const updates = req.body.updates; // [{ postId, views, likes }]
  const bulkOps = updates.map(u => ({
    updateOne: {
      filter: { postId: u.postId },
      update: { $inc: { views: u.views, likes: u.likes } }
    }
  }));

  await Analytics.bulkWrite(bulkOps);

  res.json({ message: "Bulk analytics updated" });
});

