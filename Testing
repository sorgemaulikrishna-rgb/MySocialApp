const request = require("supertest");
const mongoose = require("mongoose");
const express = require("express");
const app = express();

app.use(express.json());

// MOCK MODELS
const Post = mongoose.model("Post", {
  userId: String,
  image: String,
  caption: String,
  likes: [String],
  comments: [
    {
      _id: String,
      userId: String,
      text: String
    }
  ]
});

// SAMPLE ROUTES FOR TEST

app.post("/post", async (req, res) => {
  const post = new Post(req.body);
  await post.save();
  res.send(post);
});

app.post("/like/:id", async (req, res) => {
  const post = await Post.findById(req.params.id);

  if (!post.likes.includes(req.body.userId)) {
    post.likes.push(req.body.userId);
  } else {
    post.likes = post.likes.filter(id => id !== req.body.userId);
  }

  await post.save();
  res.send(post);
});

app.post("/comment/:id", async (req, res) => {
  const post = await Post.findById(req.params.id);

  post.comments.push({
    _id: new Date().toISOString(),
    userId: req.body.userId,
    text: req.body.text
  });

  await post.save();
  res.send(post);
});

// TESTS

describe("API TESTING", () => {

  let postId = "";

  beforeAll(async () => {
    await mongoose.connect("mongodb://127.0.0.1:27017/testdb");
  });

  afterAll(async () => {
    await mongoose.connection.close();
  });

  test("CREATE POST", async () => {
    const res = await request(app)
      .post("/post")
      .send({
        userId: "user1",
        image: "img.jpg",
        caption: "test"
      });

    expect(res.statusCode).toBe(200);
    expect(res.body.userId).toBe("user1");

    postId = res.body._id;
  });

  test("LIKE POST", async () => {
    const res = await request(app)
      .post("/like/" + postId)
      .send({ userId: "user1" });

    expect(res.statusCode).toBe(200);
    expect(res.body.likes.includes("user1")).toBe(true);
  });

  test("UNLIKE POST", async () => {
    const res = await request(app)
      .post("/like/" + postId)
      .send({ userId: "user1" });

    expect(res.statusCode).toBe(200);
    expect(res.body.likes.includes("user1")).toBe(false);
  });

  test("COMMENT POST", async () => {
    const res = await request(app)
      .post("/comment/" + postId)
      .send({
        userId: "user1",
        text: "Nice post"
      });

    expect(res.statusCode).toBe(200);
    expect(res.body.comments.length).toBeGreaterThan(0);
  });

});
