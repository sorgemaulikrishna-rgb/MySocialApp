// FILTERS SYSTEM (INSTAGRAM-LIKE IMAGE FILTERS)

const Jimp = require("jimp");

// APPLY FILTER TO IMAGE
app.post("/filter/apply", async (req, res) => {
  const { imagePath, filterType } = req.body; // imagePath = uploads/xyz.jpg

  try {
    const image = await Jimp.read(imagePath);

    switch (filterType) {
      case "grayscale":
        image.grayscale();
        break;
      case "invert":
        image.invert();
        break;
      case "sepia":
        image.sepia();
        break;
      case "blur":
        image.blur(5);
        break;
      case "brightness":
        image.brightness(0.3);
        break;
      case "contrast":
        image.contrast(0.5);
        break;
      default:
        break;
    }

    const newPath = imagePath.replace(/(\.\w+)$/, `_filtered$1`);
    await image.writeAsync(newPath);

    res.json({ message: "Filter applied", filteredImage: newPath });
  } catch (err) {
    res.status(500).json({ message: "Error applying filter", error: err.message });
  }
});

// GET AVAILABLE FILTERS
app.get("/filter/list", (req, res) => {
  const filters = ["grayscale", "invert", "sepia", "blur", "brightness", "contrast"];
  res.json({ filters });
});
