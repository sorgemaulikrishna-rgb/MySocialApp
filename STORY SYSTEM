// STORY MODEL
const Story = mongoose.model("Story", {
  userId: String,
  media: String,
  caption: String,
  viewers: [String],
  createdAt: { type: Date, default: Date.now, expires: 86400 }
});


// ADD STORY
app.post("/story", async (req, res) => {
  const story = new Story(req.body);
  await story.save();

  res.json({
    message: "Story Added",
    story: story
  });
});


// GET ALL STORIES (ACTIVE 24H)
app.get("/stories", async (req, res) => {
  const stories = await Story.find().sort({ createdAt: -1 });

  res.json({
    totalStories: stories.length,
    stories: stories
  });
});


// GET STORIES BY USER
app.get("/stories/:userId", async (req, res) => {
  const stories = await Story.find({ userId: req.params.userId });

  res.json({
    totalStories: stories.length,
    stories: stories
  });
});


// VIEW STORY (ADD VIEWER)
app.post("/story/view/:storyId", async (req, res) => {
  const { userId } = req.body;

  const story = await Story.findById(req.params.storyId);

  if (!story.viewers.includes(userId)) {
    story.viewers.push(userId);
  }

  await story.save();

  res.json({
    message: "Story Viewed",
    totalViews: story.viewers.length
  });
});


// GET STORY VIEWS
app.get("/story/views/:storyId", async (req, res) => {
  const story = await Story.findById(req.params.storyId);

  res.json({
    totalViews: story.viewers.length,
    viewers: story.viewers
  });
});


// DELETE STORY
app.post("/story/delete/:storyId", async (req, res) => {
  await Story.findByIdAndDelete(req.params.storyId);

  res.json({
    message: "Story Deleted"
  });
});


// CLEAR ALL STORIES (ADMIN)
app.post("/stories/clear", async (req, res) => {
  await Story.deleteMany({});

  res.json({
    message: "All Stories Cleared"
  });
});
