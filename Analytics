// GET POST ANALYTICS
app.get("/analytics/:postId", async (req, res) => {
  const data = await Analytics.findOne({ postId: req.params.postId });

  res.json(data);
});


// USER ANALYTICS (TOTAL)
app.get("/analytics/user/:userId", async (req, res) => {
  const posts = await Post.find({ userId: req.params.userId });

  let totalViews = 0;
  let totalLikes = 0;
  let totalComments = 0;
  let totalShares = 0;
  let totalSaves = 0;

  for (let post of posts) {
    const data = await Analytics.findOne({ postId: post._id });

    if (data) {
      totalViews += data.views;
      totalLikes += data.likes;
      totalComments += data.comments;
      totalShares += data.shares;
      totalSaves += data.saves;
    }
  }

  res.json({
    totalViews,
    totalLikes,
    totalComments,
    totalShares,
    totalSaves
  });
});


// TRENDING POSTS (BY LIKES + VIEWS)
app.get("/analytics/trending", async (req, res) => {
  const all = await Analytics.find();

  const sorted = all.sort((a, b) => {
    const scoreA = a.likes + a.views;
    const scoreB = b.likes + b.views;
    return scoreB - scoreA;
  });

  res.json(sorted.slice(0, 10));
});
